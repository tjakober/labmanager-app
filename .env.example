# ── Server ────────────────────────────────────────────────────────────────────
APP_PORT=3003
NODE_ENV=production
APP_LANG=de
APP_BASE_URL=https://fablab.example.com

# ── Datenbank (DB_HOST/DB_PORT im Container automatisch gesetzt) ──────────────
# SQL-Export: leer lassen (automatisch mariadb-dump in Docker / mysqldump lokal)
# DB_DUMP_CMD=

DB_NAME=fablabwinti
DB_USER=fablab
DB_PASSWORD=sicheres_passwort_hier
DB_ROOT_PASSWORD=sicheres_root_passwort_hier

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=HIER_LANGEN_ZUFALLSSTRING_EINSETZEN
JWT_EXPIRES_IN=8h

# ── Webling ───────────────────────────────────────────────────────────────────
WEBLING_API_URL=https://fablabwinti.webling.ch/api/1
WEBLING_API_KEY=webling_api_key_hier
WEBLING_RATE_DELAY_MS=300
WEBLING_FIELD_BALANCE=Guthaben
WEBLING_FIELD_UPGRADE_STATUS=Upgrade
WEBLING_FIELD_UPGRADE_START=Upgrade ab
WEBLING_FIELD_UPGRADE_ABLAUF=Upgrade bis
WEBLING_FIELD_UPGRADE_HISTORY=Membership-History

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://fablab.example.com/api/browser/google/callback
GOOGLE_CALENDAR_ID=

# ── Slack (optional) ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── E-Mail ────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=mail@example.com
MAIL_PASSWORD=app_passwort_hier
MAIL_FROM=FabLab Winti <mail@example.com>